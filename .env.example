# Azure AI (default provider)
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_KEY=your-api-key
AZURE_DEPLOYMENT=gpt-4o
AZURE_IMAGE_DEPLOYMENT=gpt-image-1
AZURE_API_VERSION=2024-12-01-preview

# Alternative providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Active provider (azure | openai | anthropic | ollama | lmstudio)
AI_PROVIDER=azure
IMAGE_PROVIDER=azure

# SMTP (for email verification and password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kochgeist.app

# App URL (used in email links)
APP_URL=http://localhost:4321
