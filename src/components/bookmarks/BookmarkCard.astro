---
interface Props {
  id: string;
  title: string;
  description: string;
  cookTime: string;
  badge?: string;
  badgeColor?: 'secondary' | 'tertiary' | 'primary';
  imageUrl?: string;
  tall?: boolean;
}

const { id, title, description, cookTime, badge, badgeColor = 'secondary', imageUrl, tall = false } = Astro.props;

const badgeClasses = {
  secondary: 'bg-secondary-container text-on-secondary-container',
  tertiary: 'bg-tertiary-container text-on-tertiary-container',
  primary: 'bg-primary-container text-on-primary-container',
};
---

<article class:list={[
  'group relative bg-surface-container-lowest rounded-xl overflow-hidden transition-all duration-300 hover:shadow-xl cursor-pointer',
  tall && 'md:row-span-2',
]}
  hx-get={`/partials/recipe-detail?id=${id}`}
  hx-target="#recipe-modal"
  hx-swap="innerHTML"
>
  <div class:list={[
    'relative overflow-hidden',
    tall ? 'h-[400px] md:h-[calc(100%-180px)]' : 'h-64',
  ]}>
    {imageUrl ? (
      <img
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        src={imageUrl}
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center">
        <span class="material-symbols-outlined text-6xl text-primary/20">restaurant</span>
      </div>
    )}
    <div class="absolute top-4 right-4 bg-surface-container-lowest/90 backdrop-blur p-2 rounded-full shadow-sm">
      <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">bookmark</span>
    </div>
  </div>
  <div class="p-6">
    <div class="flex gap-2 mb-3">
      {badge && (
        <span class:list={[badgeClasses[badgeColor], 'text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full']}>
          {badge}
        </span>
      )}
      <span class="bg-surface-container-high text-on-surface-variant text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">{cookTime}</span>
    </div>
    <h3 class:list={[
      'font-headline font-bold text-on-surface leading-tight mb-2 group-hover:text-primary transition-colors',
      tall ? 'text-2xl font-extrabold' : 'text-xl',
    ]}>{title}</h3>
    <p class="text-on-surface-variant text-sm line-clamp-2 mb-4">{description}</p>
    <div class="flex items-center justify-between pt-4 border-t border-outline-variant/20">
      <span class="text-xs font-bold text-on-surface-variant">EDITORIAL PICK</span>
      <button class="text-primary font-bold text-xs uppercase tracking-widest flex items-center gap-1 group/btn">
        Cook Now
        <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">arrow_forward</span>
      </button>
    </div>
  </div>
</article>
