---
import { t, type Locale } from '../../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;
---

<div class="fixed bottom-24 left-0 w-full px-6 pointer-events-none z-40">
  <div class="max-w-2xl mx-auto flex flex-col items-center gap-3" x-data="{ showSurprise: false }">

    <!-- Surprise Me prompt -->
    <div
      x-show="showSurprise"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 translate-y-4 scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 translate-y-4 scale-95"
      class="pointer-events-auto w-full bg-surface-container-lowest rounded-2xl shadow-2xl border border-outline-variant/15 p-5"
      x-cloak
    >
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-full bg-tertiary-container/30 flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-tertiary text-xl" style="font-variation-settings: 'FILL' 1;">casino</span>
        </div>
        <div class="flex-1 min-w-0">
          <h4 class="font-headline font-bold text-on-surface text-sm mb-0.5">{t('home.surpriseTitle', lang)}</h4>
          <p class="font-body text-on-surface-variant text-xs leading-relaxed">{t('home.surpriseBody', lang)}</p>
        </div>
      </div>
      <div class="flex gap-2 mt-4">
        <button
          x-on:click="
            showSurprise = false;
            $store.ui.loading = true;
            htmx.ajax('POST', '/api/recipes/suggest', {
              target: '#main-content',
              swap: 'innerHTML',
              values: {
                ingredients: JSON.stringify([]),
                filters: JSON.stringify($store.filters.active),
                lang: $store.ui.lang,
                surpriseMe: 'true'
              }
            }).finally(() => { $store.ui.loading = false; });
          "
          class="flex-1 py-2.5 rounded-full editorial-gradient text-white font-headline font-bold text-sm flex items-center justify-center gap-2 hover:opacity-95 active:scale-95 transition-all"
        >
          <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
          {t('home.surpriseConfirm', lang)}
        </button>
        <button
          x-on:click="showSurprise = false"
          class="flex-1 py-2.5 rounded-full bg-surface-container text-on-surface font-headline font-bold text-sm hover:bg-surface-container-high active:scale-95 transition-all"
        >
          {t('home.surpriseDismiss', lang)}
        </button>
      </div>
    </div>

    <!-- Suggest button -->
    <button
      id="suggest-btn"
      class="pointer-events-auto w-full py-5 rounded-full editorial-gradient text-white font-headline font-bold text-lg shadow-2xl flex items-center justify-center gap-3 hover:opacity-95 active:scale-95 transition-all duration-200"
      x-on:click="
        if ($store.ingredients.items.length === 0) { showSurprise = true; return; }
        $store.ui.loading = true;
        htmx.ajax('POST', '/api/recipes/suggest', {
          target: '#main-content',
          swap: 'innerHTML',
          values: {
            ingredients: JSON.stringify($store.ingredients.items),
            filters: JSON.stringify($store.filters.active),
            lang: $store.ui.lang
          }
        }).finally(() => { $store.ui.loading = false; });
      "
    >
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
      {t('home.suggestButton', lang)}
    </button>
  </div>
</div>
