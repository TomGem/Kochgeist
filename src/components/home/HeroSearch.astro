---
import { t, type Locale } from '../../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;
---

<section class="mb-12">
  <h2 class="font-headline font-bold text-4xl mb-6 tracking-tight leading-tight text-on-surface">
    {t('home.hero', lang)}
  </h2>
  <div class="relative group" x-data="{ input: '', focused: false }">
    <div
      class="flex items-center gap-3 bg-white/80 px-5 py-4.5 rounded-2xl border border-outline/15 shadow-sm transition-all duration-200"
      :class="focused && 'ring-2 ring-primary/30 border-primary/30 shadow-md'"
    >
      <span
        class="material-symbols-outlined text-xl transition-colors duration-200"
        :class="focused ? 'text-primary' : 'text-outline'"
      >search</span>
      <input
        x-model="input"
        x-on:keydown.enter.prevent="if (input.trim()) { $store.ingredients.add(input); input = ''; }"
        x-on:focus="focused = true"
        x-on:blur="focused = false"
        class="w-full bg-transparent border-none focus:ring-0 focus:outline-none text-on-surface placeholder:text-outline/70 p-0 font-body text-base"
        placeholder={t('home.searchPlaceholder', lang)}
        type="text"
      />
    </div>
  </div>
</section>
