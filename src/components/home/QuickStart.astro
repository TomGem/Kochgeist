---
import { t, type Locale } from '../../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;

const quickStarts = [
  {
    icon: 'eco',
    iconColor: 'text-secondary',
    bg: 'bg-surface-container-low hover:bg-surface-container-high',
    titleKey: 'home.leafyGreens' as const,
    descKey: 'home.leafyGreensCount' as const,
    ingredients: {
      en: ['Spinach', 'Arugula', 'Feta', 'Lemon', 'Pine Nuts'],
      de: ['Spinat', 'Rucola', 'Feta', 'Zitrone', 'Pinienkerne'],
    },
  },
  {
    icon: 'bolt',
    iconColor: 'text-tertiary',
    bg: 'bg-tertiary-container/10 border border-tertiary-container/20 hover:bg-tertiary-container/20',
    titleKey: 'home.quickMeals' as const,
    descKey: 'home.quickMealsDesc' as const,
    ingredients: {
      en: ['Pasta', 'Garlic', 'Olive Oil', 'Parmesan', 'Chili Flakes'],
      de: ['Pasta', 'Knoblauch', 'Olivenöl', 'Parmesan', 'Chiliflocken'],
    },
  },
];
---

<section class="mb-8">
  <div class="flex items-end justify-between mb-6">
    <h3 class="font-headline font-bold text-xl">{t('home.quickStart', lang)}</h3>
    <span class="text-primary font-label text-xs uppercase font-bold tracking-widest">{t('home.chefRecommended', lang)}</span>
  </div>
  <div class="grid grid-cols-2 gap-4">
    {quickStarts.map((qs) => (
      <div
        class:list={['col-span-1 p-4 rounded-2xl flex flex-col justify-between aspect-square cursor-pointer transition-colors', qs.bg]}
        x-data
        x-on:click={`
          $store.ingredients.clear();
          ${qs.ingredients[lang].map(i => `$store.ingredients.add('${i.replace(/'/g, "\\'")}')`).join('; ')};
          $store.ui.loading = true;
          htmx.ajax('POST', '/api/recipes/suggest', {
            target: '#main-content',
            swap: 'innerHTML',
            values: {
              ingredients: JSON.stringify($store.ingredients.items),
              filters: JSON.stringify($store.filters.active),
              lang: $store.ui.lang
            }
          }).finally(() => { $store.ui.loading = false; });
        `}
      >
        <span class:list={['material-symbols-outlined', qs.iconColor]}>{qs.icon}</span>
        <div>
          <p class="font-headline font-bold text-lg leading-tight">{t(qs.titleKey, lang)}</p>
          <p class="text-xs text-on-surface-variant mt-1">{t(qs.descKey, lang)}</p>
        </div>
      </div>
    ))}
  </div>
</section>
