---
import LanguageSwitcher from '../shared/LanguageSwitcher.astro';
import { t, type Locale } from '../../lib/i18n/index';

interface Props {
  showBack?: boolean;
}

const { showBack = false } = Astro.props;
const user = Astro.locals.user;
const lang = (Astro.locals.lang ?? 'en') as Locale;
---

<header class="fixed top-0 w-full z-50 glass-header">
  <div class="flex justify-between items-center px-6 h-16 w-full max-w-7xl mx-auto">
    <div class="flex items-center gap-3">
      {showBack && (
        <button
          onclick="history.back()"
          class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-surface-container-high transition-colors active:scale-95 duration-200"
        >
          <span class="material-symbols-outlined text-on-surface">arrow_back</span>
        </button>
      )}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" class="w-8 h-8 shrink-0 rounded-lg">
        <defs>
          <linearGradient id="hdr-bg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#ff8a56"/>
            <stop offset="50%" stop-color="#e85a1e"/>
            <stop offset="100%" stop-color="#8a2c00"/>
          </linearGradient>
          <linearGradient id="hdr-gloss" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fff" stop-opacity="0.25"/>
            <stop offset="40%" stop-color="#fff" stop-opacity="0.05"/>
            <stop offset="100%" stop-color="#000" stop-opacity="0.1"/>
          </linearGradient>
          <linearGradient id="hdr-pot" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fff"/>
            <stop offset="100%" stop-color="#e0dbd6"/>
          </linearGradient>
          <linearGradient id="hdr-rim" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fff"/>
            <stop offset="100%" stop-color="#ebe6e1"/>
          </linearGradient>
          <linearGradient id="hdr-steam" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fff" stop-opacity="0.98"/>
            <stop offset="100%" stop-color="#f5ebe5" stop-opacity="0.85"/>
          </linearGradient>
          <linearGradient id="hdr-steamSide" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fff" stop-opacity="0.8"/>
            <stop offset="100%" stop-color="#f0e4db" stop-opacity="0.6"/>
          </linearGradient>
          <linearGradient id="hdr-handle" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#fff"/>
            <stop offset="100%" stop-color="#ddd8d3"/>
          </linearGradient>
          <filter id="hdr-potShadow" x="-5%" y="-5%" width="110%" height="120%">
            <feDropShadow dx="0" dy="1.5" stdDeviation="1.5" flood-color="#6b2000" flood-opacity="0.2"/>
          </filter>
          <filter id="hdr-rimShadow" x="-5%" y="-10%" width="110%" height="130%">
            <feDropShadow dx="0" dy="1" stdDeviation="0.8" flood-color="#6b2000" flood-opacity="0.15"/>
          </filter>
          <filter id="hdr-steamGlow" x="-10%" y="-5%" width="120%" height="110%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#6b2000" flood-opacity="0.08"/>
          </filter>
        </defs>
        <rect width="128" height="128" rx="28" fill="url(#hdr-bg)"/>
        <rect width="128" height="128" rx="28" fill="url(#hdr-gloss)"/>
        <rect x="18" y="80" width="16" height="7" rx="3.5" fill="url(#hdr-handle)" filter="url(#hdr-potShadow)"/>
        <rect x="94" y="80" width="16" height="7" rx="3.5" fill="url(#hdr-handle)" filter="url(#hdr-potShadow)"/>
        <rect x="28" y="76" width="72" height="8" rx="4" fill="url(#hdr-rim)" filter="url(#hdr-rimShadow)"/>
        <path d="M32 84h64v16c0 6.6-5.4 12-12 12H44c-6.6 0-12-5.4-12-12V84z" fill="url(#hdr-pot)" filter="url(#hdr-potShadow)"/>
        <path d="M34 84h60v3c0 0-15 3-30 3s-30-3-30-3V84z" fill="#fff" opacity="0.3"/>
        <path d="M64 14c-4 6-10 14-10 22 0 5 3 8 3 14s-4 10-4 15c0 7 5 11 11 11s11-4 11-11c0-5-4-9-4-15s3-9 3-14c0-8-6-16-10-22z" fill="url(#hdr-steam)" filter="url(#hdr-steamGlow)"/>
        <path d="M45 34c-2.5 4-6 9-6 14 0 3 2 6 2 10s-2.5 7-2.5 10c0 4.5 3 7 6.5 7s6.5-2.5 6.5-7c0-3-2.5-6-2.5-10s2-7 2-10c0-5-3.5-10-6-14z" fill="url(#hdr-steamSide)" filter="url(#hdr-steamGlow)"/>
        <path d="M83 34c-2.5 4-6 9-6 14 0 3 2 6 2 10s-2.5 7-2.5 10c0 4.5 3 7 6.5 7s6.5-2.5 6.5-7c0-3-2.5-6-2.5-10s2-7 2-10c0-5-3.5-10-6-14z" fill="url(#hdr-steamSide)" filter="url(#hdr-steamGlow)"/>
      </svg>
      <h1 class="font-headline font-extrabold text-xl tracking-tighter text-primary uppercase">Kochgeist</h1>
    </div>
    <div class="flex items-center gap-3">
      <LanguageSwitcher />
      {user ? (
        <div class="relative" x-data="{ open: false }">
          <button
            x-on:click="open = !open"
            class="w-10 h-10 rounded-full flex items-center justify-center bg-primary/10 hover:bg-primary/20 transition-colors active:scale-95 duration-200"
          >
            <span class="material-symbols-outlined text-primary">account_circle</span>
          </button>
          <div
            x-show="open"
            x-on:click.outside="open = false"
            x-transition:enter="transition ease-out duration-100"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            x-transition:leave="transition ease-in duration-75"
            x-transition:leave-start="opacity-100 scale-100"
            x-transition:leave-end="opacity-0 scale-95"
            x-cloak
            class="absolute right-0 mt-2 w-56 bg-surface-container-lowest rounded-xl shadow-xl border border-outline-variant/10 overflow-hidden z-50"
          >
            <div class="px-4 py-3 border-b border-outline-variant/10">
              <p class="text-sm font-medium text-on-surface truncate">{user.displayName || user.email}</p>
              {user.displayName && <p class="text-xs text-on-surface-variant truncate">{user.email}</p>}
            </div>
            <div class="py-1">
              <a href="/settings" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-high transition-colors">
                <span class="material-symbols-outlined text-sm">settings</span>
                {t('auth.settings', lang)}
              </a>
              {user.role === 'admin' && (
                <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-high transition-colors">
                  <span class="material-symbols-outlined text-sm">admin_panel_settings</span>
                  {t('admin.title', lang)}
                </a>
              )}
            </div>
            <div class="border-t border-outline-variant/10 py-1">
              <form action="/api/auth/logout" method="POST">
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-error hover:bg-error-container/10 transition-colors">
                  <span class="material-symbols-outlined text-sm">logout</span>
                  {t('auth.logout', lang)}
                </button>
              </form>
            </div>
          </div>
        </div>
      ) : (
        <a href="/login" class="flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium transition-colors active:scale-95 duration-200">
          <span class="material-symbols-outlined text-sm">login</span>
          {t('auth.login', lang)}
        </a>
      )}
    </div>
  </div>
</header>
