---
interface Props {
  id: string;
  title: string;
  description: string;
  cookTime: string;
  difficulty: string;
  imageUrl?: string;
}

const { id, title, description, cookTime, difficulty, imageUrl } = Astro.props;
---

<article
  class="md:col-span-4 group flex flex-col rounded-xl bg-surface-container-lowest recipe-card-shadow transition-all duration-300 hover:-translate-y-1 overflow-hidden cursor-pointer"
  hx-get={`/partials/recipe-detail?id=${id}`}
  hx-target="#recipe-modal"
  hx-swap="innerHTML"
>
  <div class="h-64 overflow-hidden relative">
    {imageUrl ? (
      <img
        alt={title}
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        src={imageUrl}
      />
    ) : (
      <div class="h-full w-full bg-gradient-to-br from-secondary/20 to-tertiary-container/30 flex items-center justify-center">
        <span class="material-symbols-outlined text-6xl text-secondary/30">soup_kitchen</span>
      </div>
    )}
  </div>
  <div class="p-6 flex-grow flex flex-col justify-between">
    <div>
      <div class="flex justify-between items-start mb-3">
        <h3 class="font-headline text-xl font-bold text-on-surface">{title}</h3>
        <button
          class="text-outline hover:text-primary transition-colors"
          x-on:click.stop
          hx-post={`/api/bookmarks`}
          hx-vals={`{"recipeId": "${id}"}`}
          hx-swap="outerHTML"
        >
          <span class="material-symbols-outlined">bookmark</span>
        </button>
      </div>
      <p class="font-body text-sm text-on-surface-variant mb-6">{description}</p>
    </div>
    <div class="flex gap-4">
      <div class="flex items-center gap-1.5">
        <span class="material-symbols-outlined text-[14px] text-primary">timer</span>
        <span class="font-label text-[10px] font-bold">{cookTime}</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="material-symbols-outlined text-[14px] text-secondary">eco</span>
        <span class="font-label text-[10px] font-bold">{difficulty.toUpperCase()}</span>
      </div>
    </div>
  </div>
</article>
