---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { t, type Locale } from '../lib/i18n/index';
import { db } from '../db/index';
import { users, passwordResets } from '../db/schema';
import { eq, and, isNull } from 'drizzle-orm';
import { hashPassword } from '../lib/auth/password';
import { invalidateAllSessions } from '../lib/auth/session';
import { hashToken } from '../lib/auth/tokens';

const lang = (Astro.locals.lang ?? 'en') as Locale;
let error = '';
let success = false;
let tokenValid = false;

const token = Astro.url.searchParams.get('token') || '';

if (!token) {
  return Astro.redirect('/forgot-password');
}

// Validate token (compare hashed)
const tokenHash = hashToken(token);
const resetEntry = db
  .select()
  .from(passwordResets)
  .where(and(eq(passwordResets.token, tokenHash), isNull(passwordResets.usedAt)))
  .get();

if (!resetEntry || resetEntry.expiresAt < new Date()) {
  error = t('auth.invalidToken', lang);
} else {
  tokenValid = true;
}

if (Astro.request.method === 'POST' && tokenValid) {
  const formData = await Astro.request.formData();
  const password = formData.get('password') as string || '';
  const confirmPassword = formData.get('confirmPassword') as string || '';

  if (password.length < 8) {
    error = t('auth.passwordTooShort', lang);
  } else if (password !== confirmPassword) {
    error = t('auth.passwordMismatch', lang);
  } else {
    const passwordHash = await hashPassword(password);
    db.update(users).set({ passwordHash, updatedAt: new Date() }).where(eq(users.id, resetEntry!.userId)).run();
    db.update(passwordResets).set({ usedAt: new Date() }).where(eq(passwordResets.id, resetEntry!.id)).run();
    invalidateAllSessions(resetEntry!.userId);
    success = true;
  }
}
---

<BaseLayout title={`Kochgeist - ${t('auth.resetPassword', lang)}`}>
  <main class="min-h-screen flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-10">
        <div class="flex items-center justify-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary text-4xl">restaurant_menu</span>
          <h1 class="font-headline font-extrabold text-3xl tracking-tighter text-primary">Kochgeist</h1>
        </div>
        <h2 class="font-headline font-bold text-2xl text-on-surface mb-2">{t('auth.resetPassword', lang)}</h2>
      </div>

      {success ? (
        <div class="bg-surface-container-low rounded-2xl p-8 text-center space-y-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-secondary-container">
            <span class="material-symbols-outlined text-on-secondary-container text-3xl">check_circle</span>
          </div>
          <p class="text-on-surface">{t('auth.passwordResetSuccess', lang)}</p>
          <a
            href="/login"
            class="inline-block editorial-gradient text-white font-headline font-bold px-8 py-3 rounded-full transition-all active:scale-[0.98]"
          >
            {t('auth.login', lang)}
          </a>
        </div>
      ) : !tokenValid ? (
        <div class="bg-surface-container-low rounded-2xl p-8 text-center space-y-6">
          <div class="bg-error-container text-on-error-container text-sm p-4 rounded-xl flex items-center gap-3 justify-center">
            <span class="material-symbols-outlined text-error">error</span>
            {error}
          </div>
          <a href="/forgot-password" class="inline-block text-sm text-primary hover:underline">
            {t('auth.requestNewLink', lang)}
          </a>
        </div>
      ) : (
        <form method="POST" class="bg-surface-container-low rounded-2xl p-8 space-y-6">
          {error && (
            <div class="bg-error-container text-on-error-container text-sm p-4 rounded-xl flex items-center gap-3">
              <span class="material-symbols-outlined text-error">error</span>
              {error}
            </div>
          )}

          <div>
            <label for="password" class="block text-sm font-medium text-on-surface mb-2">{t('auth.newPassword', lang)}</label>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
              <input
                type="password"
                id="password"
                name="password"
                required
                minlength="8"
                autocomplete="new-password"
                class="w-full bg-surface-container-highest rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30"
                placeholder="••••••••"
              />
            </div>
            <p class="text-xs text-on-surface-variant mt-1">{t('auth.passwordMinLength', lang)}</p>
          </div>

          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-on-surface mb-2">{t('auth.confirmPassword', lang)}</label>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                required
                minlength="8"
                autocomplete="new-password"
                class="w-full bg-surface-container-highest rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30"
                placeholder="••••••••"
              />
            </div>
          </div>

          <button
            type="submit"
            class="w-full editorial-gradient text-white font-headline font-bold py-3 rounded-full transition-all active:scale-[0.98]"
          >
            {t('auth.resetPassword', lang)}
          </button>
        </form>
      )}
    </div>
  </main>
</BaseLayout>
