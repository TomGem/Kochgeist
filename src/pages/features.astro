---
import BaseLayout from '../components/layout/BaseLayout.astro';
import LanguageSwitcher from '../components/shared/LanguageSwitcher.astro';
import { t, type Locale } from '../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;

const features = [
  { key: 'aiRecipes', icon: 'auto_awesome', color: 'primary' },
  { key: 'scanner', icon: 'photo_camera', color: 'tertiary' },
  { key: 'cookingMode', icon: 'skillet', color: 'secondary' },
  { key: 'filters', icon: 'tune', color: 'primary' },
  { key: 'shoppingList', icon: 'checklist', color: 'tertiary' },
  { key: 'shortcuts', icon: 'bolt', color: 'secondary' },
  { key: 'community', icon: 'group', color: 'primary' },
  { key: 'surpriseMe', icon: 'casino', color: 'tertiary' },
  { key: 'sharing', icon: 'share', color: 'secondary' },
  { key: 'multilingual', icon: 'translate', color: 'primary' },
] as const;
---

<BaseLayout title={`Kochgeist - ${t('features.title', lang)}`}>
  <main class="min-h-screen">
    <!-- Header -->
    <div class="px-6 pt-6 pb-2 flex items-center justify-between max-w-3xl mx-auto">
      <a href="/login" class="inline-flex items-center gap-1 text-sm text-on-surface-variant hover:text-primary transition-colors">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        {t('features.backToLogin', lang)}
      </a>
      <LanguageSwitcher />
    </div>

    <!-- Hero -->
    <section class="px-6 pt-8 pb-16 text-center max-w-3xl mx-auto">
      <div class="flex flex-col items-center gap-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" class="w-16 h-16" aria-hidden="true">
          <defs>
            <linearGradient id="feat-pot" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--color-primary)"/>
              <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.85"/>
            </linearGradient>
            <linearGradient id="feat-steam" x1="0" y1="1" x2="0" y2="0">
              <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.7"/>
              <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.1"/>
            </linearGradient>
          </defs>
          <rect x="14" y="78" width="18" height="7" rx="3.5" fill="var(--color-primary)" opacity="0.7"/>
          <rect x="96" y="78" width="18" height="7" rx="3.5" fill="var(--color-primary)" opacity="0.7"/>
          <rect x="26" y="74" width="76" height="9" rx="4.5" fill="var(--color-primary)"/>
          <path d="M30 83h68v18c0 7.2-5.8 13-13 13H43c-7.2 0-13-5.8-13-13V83z" fill="url(#feat-pot)"/>
          <path d="M32 83h64v3c0 0-16 3-32 3s-32-3-32-3V83z" fill="var(--color-on-primary)" opacity="0.15"/>
          <path d="M64 18c-3.5 5-8 11-8 18 0 4 2.5 7 2.5 12s-3 8-3 12c0 5.5 4 9 8.5 9s8.5-3.5 8.5-9c0-4-3-8-3-12s2.5-8 2.5-12c0-7-4.5-13-8-18z" fill="url(#feat-steam)"/>
          <path d="M44 36c-2 3.5-5 7.5-5 12 0 2.5 1.5 5 1.5 8.5s-2 6-2 8.5c0 3.5 2.5 6 5.5 6s5.5-2.5 5.5-6c0-2.5-2-5-2-8.5s1.5-6 1.5-8.5c0-4.5-3-8.5-5-12z" fill="url(#feat-steam)" opacity="0.8"/>
          <path d="M84 36c-2 3.5-5 7.5-5 12 0 2.5 1.5 5 1.5 8.5s-2 6-2 8.5c0 3.5 2.5 6 5.5 6s5.5-2.5 5.5-6c0-2.5-2-5-2-8.5s1.5-6 1.5-8.5c0-4.5-3-8.5-5-12z" fill="url(#feat-steam)" opacity="0.8"/>
        </svg>
        <h1 class="font-headline font-extrabold text-3xl tracking-tighter text-primary">Kochgeist</h1>
      </div>
      <p class="text-on-surface-variant text-lg max-w-md mx-auto leading-relaxed">{t('features.subtitle', lang)}</p>
    </section>

    <!-- Feature grid -->
    <section class="px-6 pb-12 max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="bg-surface-container-low rounded-2xl p-6 recipe-card-shadow">
            <div class:list={[
              'w-11 h-11 rounded-xl flex items-center justify-center mb-4',
              f.color === 'primary' && 'bg-primary/10',
              f.color === 'secondary' && 'bg-secondary/10',
              f.color === 'tertiary' && 'bg-tertiary/10',
            ]}>
              <span class:list={[
                'material-symbols-outlined text-2xl',
                f.color === 'primary' && 'text-primary',
                f.color === 'secondary' && 'text-secondary',
                f.color === 'tertiary' && 'text-tertiary',
              ]}>{f.icon}</span>
            </div>
            <h3 class="font-headline font-bold text-on-surface mb-1.5">{t(`features.${f.key}`, lang)}</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">{t(`features.${f.key}Desc`, lang)}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 pb-16 text-center max-w-3xl mx-auto">
      <a
        href="/register"
        class="inline-flex items-center gap-2 editorial-gradient text-white font-headline font-bold py-3 px-8 rounded-full transition-all active:scale-[0.98]"
      >
        {t('features.cta', lang)}
        <span class="material-symbols-outlined text-lg">arrow_forward</span>
      </a>
    </section>
  </main>
</BaseLayout>
