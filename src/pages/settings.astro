---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import BottomNav from '../components/layout/BottomNav.astro';
import { t, type Locale } from '../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;

const aiProvider = import.meta.env.AI_PROVIDER || 'azure';
const imageProvider = import.meta.env.IMAGE_PROVIDER || 'azure';

const providers = [
  { id: 'azure', name: 'Microsoft Azure AI', description: 'Azure OpenAI Service (GPT-4o)' },
  { id: 'openai', name: 'OpenAI', description: 'GPT-4o direct' },
  { id: 'anthropic', name: 'Anthropic', description: 'Claude Sonnet' },
  { id: 'ollama', name: 'Ollama', description: 'Local model (free)' },
  { id: 'lmstudio', name: 'LM Studio', description: 'Local model (free)' },
];
---

<BaseLayout title="Kochgeist - Settings">
  <Header showBack={true} />

  <main class="pt-24 pb-32 px-6 max-w-2xl mx-auto min-h-screen">
    <h2 class="font-headline font-bold text-4xl mb-2 tracking-tight text-on-surface">Settings</h2>
    <p class="text-on-surface-variant mb-12">Configure your AI providers and preferences.</p>

    <!-- AI Text Provider -->
    <section class="mb-12">
      <h3 class="font-headline font-bold text-xl mb-6">Recipe AI Provider</h3>
      <div class="space-y-3">
        {providers.map((p) => (
          <div class:list={[
            'p-4 rounded-xl transition-colors',
            aiProvider === p.id ? 'bg-primary/10 border-2 border-primary/30' : 'bg-surface-container-low hover:bg-surface-container-high',
          ]}>
            <div class="flex items-center justify-between">
              <div>
                <p class="font-headline font-bold text-on-surface">{p.name}</p>
                <p class="text-sm text-on-surface-variant">{p.description}</p>
              </div>
              {aiProvider === p.id && (
                <span class="text-[10px] font-bold uppercase tracking-wider bg-primary text-on-primary px-2 py-1 rounded-full">Active</span>
              )}
            </div>
          </div>
        ))}
      </div>
      <p class="text-xs text-on-surface-variant mt-4">
        To change the active provider, set the <code class="bg-surface-container-high px-1 py-0.5 rounded">AI_PROVIDER</code> environment variable.
      </p>
    </section>

    <!-- Image Provider -->
    <section class="mb-12">
      <h3 class="font-headline font-bold text-xl mb-6">Image Generation</h3>
      <div class:list={[
        'p-4 rounded-xl',
        imageProvider === 'azure' ? 'bg-primary/10 border-2 border-primary/30' : 'bg-surface-container-low',
      ]}>
        <div class="flex items-center justify-between">
          <div>
            <p class="font-headline font-bold text-on-surface">Azure AI (gpt-image-1)</p>
            <p class="text-sm text-on-surface-variant">AI-generated food photography</p>
          </div>
          <span class="text-[10px] font-bold uppercase tracking-wider bg-primary text-on-primary px-2 py-1 rounded-full">Active</span>
        </div>
      </div>
      <p class="text-xs text-on-surface-variant mt-4">
        Set <code class="bg-surface-container-high px-1 py-0.5 rounded">IMAGE_PROVIDER=placeholder</code> to disable image generation.
      </p>
    </section>

    <!-- Environment Status -->
    <section class="mb-12">
      <h3 class="font-headline font-bold text-xl mb-6">Environment</h3>
      <div class="space-y-3">
        <div class="flex justify-between p-4 bg-surface-container-low rounded-xl">
          <span class="text-sm font-medium">AZURE_ENDPOINT</span>
          <span class="text-sm text-on-surface-variant">{import.meta.env.AZURE_ENDPOINT ? 'Set' : 'Not set'}</span>
        </div>
        <div class="flex justify-between p-4 bg-surface-container-low rounded-xl">
          <span class="text-sm font-medium">AZURE_API_KEY</span>
          <span class="text-sm text-on-surface-variant">{import.meta.env.AZURE_API_KEY ? 'Set' : 'Not set'}</span>
        </div>
        <div class="flex justify-between p-4 bg-surface-container-low rounded-xl">
          <span class="text-sm font-medium">Language</span>
          <span class="text-sm text-on-surface-variant">{lang.toUpperCase()}</span>
        </div>
      </div>
    </section>
  </main>

  <BottomNav />
</BaseLayout>
