---
import BaseLayout from '../components/layout/BaseLayout.astro';
import FeedCard from '../components/feed/FeedCard.astro';
import LanguageSwitcher from '../components/shared/LanguageSwitcher.astro';
import { t, type Locale } from '../lib/i18n/index';
import { db } from '../db/index';
import { users, recipes } from '../db/schema';
import { eq, isNotNull, desc } from 'drizzle-orm';
import { verifyPassword } from '../lib/auth/password';
import { createSession, setSessionCookie } from '../lib/auth/session';
import { isRateLimited } from '../lib/rate-limit';

const lang = (Astro.locals.lang ?? 'en') as Locale;
let error = '';

// Already logged in? Redirect to home
if (Astro.locals.user) {
  return Astro.redirect('/');
}

if (Astro.request.method === 'POST') {
  const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || 'unknown';
  const formData = await Astro.request.formData();
  const email = (formData.get('email') as string || '').trim().toLowerCase();
  const password = formData.get('password') as string || '';

  if (isRateLimited(`login:${clientIp}`, 10, 15 * 60 * 1000)) {
    error = t('auth.tooManyAttempts', lang);
  } else if (!email || !password) {
    error = t('auth.invalidCredentials', lang);
  } else {
    const user = db.select().from(users).where(eq(users.email, email)).get();
    if (!user || !(await verifyPassword(password, user.passwordHash))) {
      error = t('auth.invalidCredentials', lang);
    } else if (!user.isVerified) {
      return Astro.redirect(`/register/verify?userId=${user.id}`);
    } else {
      const sessionId = createSession(user.id);
      setSessionCookie(Astro.cookies, sessionId);
      return Astro.redirect('/');
    }
  }
}

const sharedRecipes = db
  .select({
    id: recipes.id,
    title: recipes.title,
    description: recipes.description,
    cookTime: recipes.cookTime,
    imageUrl: recipes.imageUrl,
  })
  .from(recipes)
  .where(isNotNull(recipes.sharedAt))
  .orderBy(desc(recipes.sharedAt))
  .limit(6)
  .all();
---

<BaseLayout title={`Kochgeist - ${t('auth.login', lang)}`}>
  <main class="min-h-screen px-6 py-12">
    <div class="flex justify-end w-full max-w-md mx-auto pt-4">
      <LanguageSwitcher />
    </div>
    <div class="w-full max-w-md mx-auto pt-8">
      <div class="text-center mb-10">
        <div class="flex flex-col items-center gap-3 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" class="w-20 h-20" aria-hidden="true">
            <defs>
              <linearGradient id="login-pot" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--color-primary)"/>
                <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.85"/>
              </linearGradient>
              <linearGradient id="login-steam" x1="0" y1="1" x2="0" y2="0">
                <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.7"/>
                <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.1"/>
              </linearGradient>
            </defs>
            <rect x="14" y="78" width="18" height="7" rx="3.5" fill="var(--color-primary)" opacity="0.7"/>
            <rect x="96" y="78" width="18" height="7" rx="3.5" fill="var(--color-primary)" opacity="0.7"/>
            <rect x="26" y="74" width="76" height="9" rx="4.5" fill="var(--color-primary)"/>
            <path d="M30 83h68v18c0 7.2-5.8 13-13 13H43c-7.2 0-13-5.8-13-13V83z" fill="url(#login-pot)"/>
            <path d="M32 83h64v3c0 0-16 3-32 3s-32-3-32-3V83z" fill="var(--color-on-primary)" opacity="0.15"/>
            <path d="M64 18c-3.5 5-8 11-8 18 0 4 2.5 7 2.5 12s-3 8-3 12c0 5.5 4 9 8.5 9s8.5-3.5 8.5-9c0-4-3-8-3-12s2.5-8 2.5-12c0-7-4.5-13-8-18z" fill="url(#login-steam)"/>
            <path d="M44 36c-2 3.5-5 7.5-5 12 0 2.5 1.5 5 1.5 8.5s-2 6-2 8.5c0 3.5 2.5 6 5.5 6s5.5-2.5 5.5-6c0-2.5-2-5-2-8.5s1.5-6 1.5-8.5c0-4.5-3-8.5-5-12z" fill="url(#login-steam)" opacity="0.8"/>
            <path d="M84 36c-2 3.5-5 7.5-5 12 0 2.5 1.5 5 1.5 8.5s-2 6-2 8.5c0 3.5 2.5 6 5.5 6s5.5-2.5 5.5-6c0-2.5-2-5-2-8.5s1.5-6 1.5-8.5c0-4.5-3-8.5-5-12z" fill="url(#login-steam)" opacity="0.8"/>
          </svg>
          <h1 class="font-headline font-extrabold text-3xl tracking-tighter text-primary">Kochgeist</h1>
        </div>
        <p class="text-on-surface-variant">{t('auth.loginSubtitle', lang)}</p>
      </div>

      <form method="POST" class="bg-surface-container-low rounded-2xl p-8 space-y-6">
        {error && (
          <div class="bg-error-container text-on-error-container text-sm p-4 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-error">error</span>
            {error}
          </div>
        )}

        <div>
          <label for="email" class="block text-sm font-medium text-on-surface mb-2">{t('auth.email', lang)}</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">mail</span>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full bg-surface-container-highest rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30"
              placeholder="you@example.com"
            />
          </div>
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-on-surface mb-2">{t('auth.password', lang)}</label>
          <div class="relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">lock</span>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full bg-surface-container-highest rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30"
              placeholder="••••••••"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full editorial-gradient text-white font-headline font-bold py-3 rounded-full transition-all active:scale-[0.98]"
        >
          {t('auth.login', lang)}
        </button>

        <div class="text-center space-y-2">
          <a href="/forgot-password" class="block text-sm text-primary hover:underline">
            {t('auth.forgotPassword', lang)}
          </a>
          <a href="/register" class="block text-sm text-primary hover:underline">
            {t('auth.noAccountYet', lang)}
          </a>
        </div>
      </form>

      <div class="mt-6 text-center">
        <a href="/features" class="inline-flex items-center gap-1.5 text-sm text-on-surface-variant hover:text-primary transition-colors">
          <span class="material-symbols-outlined text-base">auto_awesome</span>
          {t('features.title', lang)}
        </a>
      </div>
    </div>

    {sharedRecipes.length > 0 && (
      <div class="w-full max-w-5xl mx-auto mt-20">
        <div class="flex items-center justify-between mb-8">
          <div>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-primary font-bold mb-1 block">{t('feed.communityRecipe', lang)}</span>
            <h2 class="font-headline text-3xl font-extrabold tracking-tighter text-on-surface">{t('feed.title', lang)}</h2>
          </div>
          <a href="/feed" class="text-primary font-bold text-sm uppercase tracking-widest flex items-center gap-1 hover:gap-2 transition-all">
            {t('feed.viewAll', lang)}
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
        <section class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {sharedRecipes.map((recipe) => (
            <FeedCard
              id={recipe.id}
              title={recipe.title}
              description={recipe.description}
              cookTime={recipe.cookTime}
              imageUrl={recipe.imageUrl}
              linkMode={true}
            />
          ))}
        </section>
      </div>
    )}
  </main>
</BaseLayout>
