---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import BottomNav from '../components/layout/BottomNav.astro';
import HeroSearch from '../components/home/HeroSearch.astro';
import IngredientTags from '../components/home/IngredientTags.astro';
import DietaryFilters from '../components/home/DietaryFilters.astro';
import FavouriteShortcuts from '../components/home/FavouriteShortcuts.astro';
import SuggestButton from '../components/home/SuggestButton.astro';
import LoadingSpinner from '../components/shared/LoadingSpinner.astro';
import ErrorToast from '../components/shared/ErrorToast.astro';
import RecipeModal from '../components/detail/RecipeModal.astro';
import { t, type Locale } from '../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;
---

<BaseLayout title={`Kochgeist - ${t('app.tagline', lang)}`} activePage="discover">
  <Header />
  <main id="main-content" class="pt-24 pb-52 px-6 max-w-2xl mx-auto min-h-screen">
    <HeroSearch />
    <IngredientTags />
    <DietaryFilters />
    <FavouriteShortcuts />
  </main>
  <SuggestButton />
  <BottomNav active="discover" />
  <RecipeModal />
  <LoadingSpinner />
  <ErrorToast />
</BaseLayout>
