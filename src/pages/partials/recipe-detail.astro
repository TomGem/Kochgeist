---
import { db } from '../../db/index';
import { recipes, bookmarks, imageCache } from '../../db/schema';
import { eq, and } from 'drizzle-orm';
import { t, type Locale } from '../../lib/i18n/index';
import { computeDetailBadge } from '../../lib/badges';
import CookingMode from '../../components/detail/CookingMode.astro';

const lang = (Astro.locals.lang ?? 'en') as Locale;
const id = Astro.url.searchParams.get('id');
if (!id) return new Response('Missing recipe ID', { status: 400 });

const recipe = db.select().from(recipes).where(eq(recipes.id, id)).get();
if (!recipe) return new Response('Recipe not found', { status: 404 });

const user = Astro.locals.user;
const isBookmarked = user
  ? !!db.select().from(bookmarks).where(and(eq(bookmarks.recipeId, id), eq(bookmarks.userId, user.id))).get()
  : false;

const imageEntry = db.select().from(imageCache).where(eq(imageCache.recipeId, id)).get();

const ingredientsList = JSON.parse(recipe.ingredients) as Array<{ name: string; amount: string; isExtra: boolean }>;
const stepsList = JSON.parse(recipe.instructions) as Array<{ step: number; title: string; description: string }>;
const dietaryTags: string[] = recipe.dietaryTags ? JSON.parse(recipe.dietaryTags) : [];

const tagMeta: Record<string, { labelKey: string; icon: string }> = {
  'vegetarian': { labelKey: 'filters.vegetarian', icon: 'eco' },
  'vegan': { labelKey: 'filters.vegan', icon: 'spa' },
  'gluten-free': { labelKey: 'filters.glutenFree', icon: 'grain' },
  'dairy-free': { labelKey: 'filters.dairyFree', icon: 'water_drop' },
  'low-carb': { labelKey: 'filters.lowCarb', icon: 'trending_down' },
  'high-protein': { labelKey: 'filters.highProtein', icon: 'fitness_center' },
  'low-cholesterol': { labelKey: 'filters.lowCholesterol', icon: 'favorite' },
  'quick': { labelKey: 'filters.quick', icon: 'timer' },
  'elaborate': { labelKey: 'filters.elaborate', icon: 'menu_book' },
  'budget': { labelKey: 'filters.budget', icon: 'savings' },
  'gourmet': { labelKey: 'filters.gourmet', icon: 'star' },
  'kid-friendly': { labelKey: 'filters.kidFriendly', icon: 'child_care' },
  'date-night': { labelKey: 'filters.dateNight', icon: 'local_dining' },
  'comfort': { labelKey: 'filters.comfort', icon: 'cottage' },
  'one-pot': { labelKey: 'filters.onePot', icon: 'soup_kitchen' },
  'meal-prep': { labelKey: 'filters.mealPrep', icon: 'kitchen' },
  'amuse-bouche': { labelKey: 'filters.amouseBouche', icon: 'tapas' },
  'starter': { labelKey: 'filters.starter', icon: 'set_meal' },
  'salad': { labelKey: 'filters.salad', icon: 'nutrition' },
  'soup': { labelKey: 'filters.soup', icon: 'ramen_dining' },
  'main-course': { labelKey: 'filters.mainCourse', icon: 'dinner_dining' },
  'dessert': { labelKey: 'filters.dessert', icon: 'cake' },
};
---

<div class="bg-surface min-h-screen" x-data x-init="$store.ui.modalOpen = true" x-on:click.self="$store.ui.modalOpen = false">
  <nav class="sticky top-0 w-full z-50 glass-header flex justify-between items-center px-6 h-16">
    <div class="flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128" class="w-9 h-9 shrink-0 -translate-y-1.5" aria-hidden="true">
        <defs>
          <linearGradient id="dt-pot" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--color-primary)"/>
            <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.85"/>
          </linearGradient>
          <linearGradient id="dt-steam" x1="0" y1="1" x2="0" y2="0">
            <stop offset="0%" stop-color="var(--color-primary)" stop-opacity="0.7"/>
            <stop offset="100%" stop-color="var(--color-primary)" stop-opacity="0.1"/>
          </linearGradient>
        </defs>
        <rect x="14" y="78" width="18" height="7" rx="3.5" fill="var(--color-primary)" opacity="0.7"/>
        <rect x="96" y="78" width="18" height="7" rx="3.5" fill="var(--color-primary)" opacity="0.7"/>
        <rect x="26" y="74" width="76" height="9" rx="4.5" fill="var(--color-primary)"/>
        <path d="M30 83h68v18c0 7.2-5.8 13-13 13H43c-7.2 0-13-5.8-13-13V83z" fill="url(#dt-pot)"/>
        <path d="M32 83h64v3c0 0-16 3-32 3s-32-3-32-3V83z" fill="var(--color-on-primary)" opacity="0.15"/>
        <path d="M64 18c-3.5 5-8 11-8 18 0 4 2.5 7 2.5 12s-3 8-3 12c0 5.5 4 9 8.5 9s8.5-3.5 8.5-9c0-4-3-8-3-12s2.5-8 2.5-12c0-7-4.5-13-8-18z" fill="url(#dt-steam)"/>
        <path d="M44 36c-2 3.5-5 7.5-5 12 0 2.5 1.5 5 1.5 8.5s-2 6-2 8.5c0 3.5 2.5 6 5.5 6s5.5-2.5 5.5-6c0-2.5-2-5-2-8.5s1.5-6 1.5-8.5c0-4.5-3-8.5-5-12z" fill="url(#dt-steam)" opacity="0.8"/>
        <path d="M84 36c-2 3.5-5 7.5-5 12 0 2.5 1.5 5 1.5 8.5s-2 6-2 8.5c0 3.5 2.5 6 5.5 6s5.5-2.5 5.5-6c0-2.5-2-5-2-8.5s1.5-6 1.5-8.5c0-4.5-3-8.5-5-12z" fill="url(#dt-steam)" opacity="0.8"/>
      </svg>
      <span class="text-xl font-extrabold text-primary tracking-tighter font-headline uppercase">Kochgeist</span>
    </div>
    <div class="flex gap-4">
      <button class="material-symbols-outlined text-on-surface hover:opacity-80 transition-opacity" x-on:click="$store.ui.modalOpen = false">close</button>
    </div>
  </nav>

  <main class="pb-20 sm:pb-32 max-w-5xl mx-auto px-4 sm:px-8">
    <!-- Hero Section -->
    <section class="mt-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <div class="lg:col-span-7 overflow-hidden rounded-xl">
        {recipe.imageUrl ? (
          <img class="w-full aspect-[4/3] object-cover hover:scale-105 transition-transform duration-700" src={recipe.imageUrl} alt={recipe.title} />
        ) : (
          <div class="w-full aspect-[4/3] bg-gradient-to-br from-primary/20 to-tertiary-container/30 flex items-center justify-center rounded-xl">
            <span class="material-symbols-outlined text-8xl text-primary/20">restaurant</span>
          </div>
        )}
      </div>
      <div class="lg:col-span-5 pb-4">
        <span class="inline-block bg-tertiary-container text-on-tertiary-container px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase mb-4">{recipe.highlight || computeDetailBadge(recipe, lang)}</span>
        <h1 class="font-headline font-extrabold text-3xl sm:text-5xl md:text-6xl text-on-surface leading-[1.1] tracking-tighter mb-4 sm:mb-6">{recipe.title}</h1>
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-full">
            <span class="material-symbols-outlined text-primary text-sm">schedule</span>
            <span class="text-xs font-semibold uppercase tracking-wider">{recipe.cookTime}</span>
          </div>
          <div class="flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-full">
            <span class="material-symbols-outlined text-secondary text-sm">bar_chart</span>
            <span class="text-xs font-semibold uppercase tracking-wider">{recipe.difficulty}</span>
          </div>
          {recipe.servings && (
            <div class="flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-full">
              <span class="material-symbols-outlined text-secondary text-sm">group</span>
              <span class="text-xs font-semibold uppercase tracking-wider">{recipe.servings}</span>
            </div>
          )}
        </div>
        {dietaryTags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {dietaryTags.map((tag) => {
              const meta = tagMeta[tag];
              return meta ? (
                <span class="inline-flex items-center gap-1.5 bg-primary-container text-on-primary-container px-3 py-1 rounded-full text-[11px] font-semibold">
                  <span class="material-symbols-outlined text-sm">{meta.icon}</span>
                  {t(meta.labelKey, lang)}
                </span>
              ) : (
                <span class="inline-flex items-center bg-primary-container text-on-primary-container px-3 py-1 rounded-full text-[11px] font-semibold">
                  {tag}
                </span>
              );
            })}
          </div>
        )}
        {recipe.aiProvider && user?.role === 'admin' && (
          <div class="flex flex-wrap items-center gap-x-5 gap-y-1.5 mt-5 text-[11px] text-on-surface-variant/50">
            <div class="flex items-center gap-1.5">
              <span class="material-symbols-outlined text-xs">smart_toy</span>
              <span>{t('meta.generatedBy', lang)} {recipe.aiProvider} / {recipe.aiModel}</span>
              {recipe.aiGenerationTimeMs && (
                <span class="text-on-surface-variant/35">({Math.round(recipe.aiGenerationTimeMs / 4 / 1000)}s)</span>
              )}
            </div>
            {imageEntry?.model && imageEntry.model !== 'placeholder' && (
              <div class="flex items-center gap-1.5">
                <span class="material-symbols-outlined text-xs">image</span>
                <span>{t('meta.imageBy', lang)} {imageEntry.provider} / {imageEntry.model}</span>
                {imageEntry.generationTimeMs && (
                  <span class="text-on-surface-variant/35">({Math.round(imageEntry.generationTimeMs / 1000)}s)</span>
                )}
              </div>
            )}
          </div>
        )}
      </div>
    </section>

    <!-- Recipe Content -->
    <div class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-16">
      <!-- Ingredients -->
      <aside class="md:col-span-1" x-data={`{
        items: ${JSON.stringify(ingredientsList.map(i => ({ amount: i.amount, name: i.name, done: false }))).replace(/</g, '\\u003c')},
        originalServings: ${(() => { const m = recipe.servings?.match(/\d+/); return m ? parseInt(m[0]) : 0; })()},
        servings: ${(() => { const m = recipe.servings?.match(/\d+/); return m ? parseInt(m[0]) : 0; })()},
        exportLabel: ${JSON.stringify(t('detail.exportList', lang))},
        emptyLabel: ${JSON.stringify(t('detail.exportEmpty', lang))},
        copiedLabel: ${JSON.stringify(t('detail.copied', lang))},
        titleLabel: ${JSON.stringify(t('detail.shoppingListFor', lang) + ' ' + recipe.title)},
        servingsLabel: ${JSON.stringify(t('metrics.servings', lang))},
        feedback: '',
        parseFrac(s) {
          const m = s.match(/^(\\d+)\\s*[/\u2044](\\d+)$/);
          return m ? parseInt(m[1]) / parseInt(m[2]) : null;
        },
        scaleAmount(amount) {
          if (!this.originalServings || this.servings === this.originalServings) return amount;
          const ratio = this.servings / this.originalServings;
          return amount.replace(/\\d+\\s*[/\u2044]\\s*\\d+|\\d+[.,]\\d+|\\d+/g, (match, offset, str) => {
            const frac = this.parseFrac(match.replace(/\\s+/g, ''));
            const num = frac !== null ? frac : parseFloat(match.replace(',', '.'));
            if (isNaN(num)) return match;
            const scaled = num * ratio;
            if (scaled === Math.round(scaled)) return String(Math.round(scaled));
            if (Math.abs(scaled - Math.round(scaled * 4) / 4) < 0.01) {
              const q = Math.round(scaled * 4);
              const whole = Math.floor(q / 4);
              const frac = q % 4;
              const fracs = ['', '1/4', '1/2', '3/4'];
              return whole && frac ? whole + ' ' + fracs[frac] : frac ? fracs[frac] : String(whole);
            }
            return (Math.round(scaled * 100) / 100).toString();
          });
        },
        itemText(item) { return this.scaleAmount(item.amount) + ' ' + item.name; },
        async exportList() {
          const needed = this.items.filter(i => !i.done);
          if (!needed.length) { this.showFeedback(this.emptyLabel); return; }
          const lines = needed.map(i => '- ' + this.itemText(i));
          const text = this.titleLabel + '\\n\\n' + lines.join('\\n');
          if (navigator.share) {
            try { await navigator.share({ title: this.titleLabel, text }); return; } catch {}
          }
          try { await navigator.clipboard.writeText(text); this.showFeedback(this.copiedLabel); } catch {}
        },
        showFeedback(msg) { this.feedback = msg; setTimeout(() => this.feedback = '', 2000); }
      }`}>
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-headline text-2xl font-bold text-on-surface">{t('detail.ingredients', lang)}</h2>
          {recipe.servings && (
            <div class="flex items-center gap-2">
              <button
                x-on:click="servings = Math.max(1, servings - 1)"
                class="w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-high hover:bg-surface-container-highest text-on-surface transition-colors cursor-pointer"
              >
                <span class="material-symbols-outlined text-base">remove</span>
              </button>
              <div class="flex items-center gap-1.5 px-2 min-w-[3.5rem] justify-center">
                <span class="material-symbols-outlined text-primary text-sm">group</span>
                <span class="text-sm font-bold text-on-surface" x-text="servings"></span>
              </div>
              <button
                x-on:click="servings++"
                class="w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-high hover:bg-surface-container-highest text-on-surface transition-colors cursor-pointer"
              >
                <span class="material-symbols-outlined text-base">add</span>
              </button>
            </div>
          )}
        </div>
        <ul class="space-y-4">
          <template x-for="(item, idx) in items" :key="idx">
            <li
              x-on:click="item.done = !item.done"
              :class="item.done && 'opacity-50'"
              class="flex items-start justify-between p-4 bg-surface-container-low rounded-xl group hover:bg-surface-container-high transition-colors cursor-pointer select-none"
            >
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium" :class="item.done && 'line-through'" x-text="itemText(item)"></span>
              </div>
              <span
                class="material-symbols-outlined transition-colors text-lg"
                :class="item.done ? 'text-green-600' : 'text-outline-variant group-hover:text-green-600'"
                :style="item.done && `font-variation-settings: 'FILL' 1`"
              >check_circle</span>
            </li>
          </template>
        </ul>

        <!-- Export Shopping List -->
        <button
          x-on:click="exportList()"
          class="mt-6 w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-surface-container-low hover:bg-surface-container-high text-on-surface text-sm font-medium transition-colors cursor-pointer"
        >
          <span class="material-symbols-outlined text-lg">share</span>
          <span x-text="feedback || exportLabel"></span>
        </button>

        <!-- Chef's Note -->
        <div class="mt-8 p-6 bg-tertiary-fixed rounded-xl border-l-4 border-on-tertiary-fixed-variant">
          <div class="flex items-center gap-2 mb-2">
            <span class="material-symbols-outlined text-on-tertiary-fixed text-lg">lightbulb</span>
            <h4 class="font-headline font-bold text-sm text-on-tertiary-fixed">{t('detail.chefsNote', lang)}</h4>
          </div>
          <p class="text-xs text-on-tertiary-fixed leading-relaxed">{recipe.description}</p>
        </div>
      </aside>

      <!-- Instructions -->
      <article class="md:col-span-2">
        <h2 class="font-headline text-2xl font-bold mb-8 text-on-surface">{t('detail.cookingSteps', lang)}</h2>
        <div class="space-y-12">
          {stepsList.map((step) => (
            <div class="flex gap-6 group">
              <span class="font-headline text-4xl font-black text-outline-variant/30 group-hover:text-primary transition-colors duration-300">
                {String(step.step).padStart(2, '0')}
              </span>
              <div class="pt-2">
                <h3 class="font-headline font-bold text-lg mb-2">{step.title}</h3>
                <p class="text-on-surface-variant leading-relaxed text-sm">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </article>
    </div>
  </main>

  <!-- Bottom Action Bar -->
  <div class="sticky bottom-0 left-0 w-full flex justify-between items-center h-16 sm:h-20 px-4 sm:px-8 pb-2 sm:pb-4 glass-nav border-t border-outline-variant/20 z-50">
    <button
      class="flex items-center gap-1.5 sm:gap-2 text-on-surface font-semibold hover:opacity-70 transition-opacity"
      x-on:click="$store.ui.modalOpen = false"
    >
      <span class="material-symbols-outlined text-xl sm:text-2xl">arrow_back</span>
      <span class="hidden sm:inline text-xs uppercase tracking-widest font-label">{t('detail.backToFeed', lang)}</span>
    </button>
    <div class="flex gap-2 lg:gap-4">
      <button
        id={`bookmark-${recipe.id}`}
        class="flex items-center lg:gap-3 bg-surface-container-highest p-2.5 lg:px-6 lg:py-3 rounded-full text-on-surface font-bold text-xs lg:text-sm transition-all active:scale-95"
        hx-post="/api/bookmarks"
        hx-vals={JSON.stringify({ recipeId: recipe.id })}
        hx-target={`#bookmark-${recipe.id}`}
        hx-swap="outerHTML"
      >
        <span class="material-symbols-outlined text-lg lg:text-2xl" style={isBookmarked ? "font-variation-settings: 'FILL' 1;" : ''}>bookmark</span>
        <span class="hidden lg:inline">{isBookmarked ? t('detail.saved', lang) : t('detail.save', lang)}</span>
      </button>
      {user && !recipe.sharedAt && (
        <span id={`share-${recipe.id}`}>
          <button
            class="flex items-center lg:gap-3 bg-surface-container-highest p-2.5 lg:px-6 lg:py-3 rounded-full text-on-surface font-bold text-xs lg:text-sm transition-all active:scale-95"
            hx-post="/api/recipes/share"
            hx-vals={JSON.stringify({ recipeId: recipe.id })}
            hx-target={`#share-${recipe.id}`}
            hx-swap="outerHTML"
          >
            <span class="material-symbols-outlined text-lg lg:text-2xl">share</span>
            <span class="hidden lg:inline">{t('detail.share', lang)}</span>
          </button>
        </span>
      )}
      {user && recipe.sharedAt && (
        <span id={`share-${recipe.id}`} class="flex gap-2 lg:gap-4">
          <button
            class="flex items-center lg:gap-3 bg-surface-container-highest p-2.5 lg:px-6 lg:py-3 rounded-full text-on-surface font-bold text-xs lg:text-sm transition-all active:scale-95"
            x-data="{ copied: false }"
            x-on:click={`navigator.clipboard.writeText(window.location.origin + '/recipe/${recipe.id}').then(() => { copied = true; $store.ui.toastMessage = '${t('detail.linkCopied', lang)}'; setTimeout(() => { $store.ui.toastMessage = null; copied = false; }, 2000); })`}
          >
            <span class="material-symbols-outlined text-lg lg:text-2xl" x-text="copied ? 'check' : 'link'">link</span>
            <span class="hidden lg:inline" x-text={`copied ? '${t('detail.linkCopied', lang)}' : '${t('detail.copyLink', lang)}'`}>{t('detail.copyLink', lang)}</span>
          </button>
          {(recipe.sharedBy === user.id || user.role === 'admin') && (
            <button
              class="flex items-center lg:gap-3 bg-surface-container-highest p-2.5 lg:px-6 lg:py-3 rounded-full text-on-surface font-bold text-xs lg:text-sm transition-all active:scale-95"
              hx-post="/api/recipes/unshare"
              hx-vals={JSON.stringify({ recipeId: recipe.id })}
              hx-target={`#share-${recipe.id}`}
              hx-swap="outerHTML"
            >
              <span class="material-symbols-outlined text-lg lg:text-2xl">visibility_off</span>
              <span class="hidden lg:inline">{t('detail.unshare', lang)}</span>
            </button>
          )}
        </span>
      )}
      <button
        x-on:click="$dispatch('start-cooking')"
        class="flex items-center lg:gap-3 editorial-gradient p-2.5 lg:px-8 lg:py-3 rounded-full text-on-primary font-bold text-xs lg:text-sm shadow-xl shadow-primary/20 transition-all active:scale-95"
      >
        <span class="material-symbols-outlined text-lg lg:text-2xl">restaurant</span>
        <span class="hidden lg:inline">{t('detail.startCooking', lang)}</span>
      </button>
    </div>
  </div>
  <CookingMode steps={stepsList} recipeTitle={recipe.title} lang={lang} />
</div>
