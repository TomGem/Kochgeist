---
import { db } from '../../db/index';
import { recipes } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { t, type Locale } from '../../lib/i18n/index';

const lang = (Astro.locals.lang ?? 'en') as Locale;
const recipeId = Astro.url.searchParams.get('recipeId');
if (!recipeId) return new Response('Missing recipeId', { status: 400 });

const recipe = db.select().from(recipes).where(eq(recipes.id, recipeId)).get();
const imageReady = recipe?.imageStatus === 'ready' && recipe?.imageUrl;
---

{imageReady ? (
  <img
    alt={recipe!.title}
    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 animate-[fadeIn_0.5s_ease-in]"
    src={recipe!.imageUrl!}
  />
) : (
  <div
    id={`image-slot-${recipeId}`}
    hx-get={`/partials/image-slot?recipeId=${encodeURIComponent(recipeId)}`}
    hx-trigger="every 3s"
    hx-target="this"
    hx-swap="outerHTML"
    class="h-full w-full bg-gradient-to-br from-primary/10 to-tertiary-container/20 flex flex-col items-center justify-center gap-3"
  >
    <span class="material-symbols-outlined text-4xl text-primary/20 animate-pulse">restaurant</span>
    <div class="flex items-center gap-2 text-on-surface-variant/50">
      <span class="material-symbols-outlined text-sm animate-spin">progress_activity</span>
      <span class="text-[10px] font-bold uppercase tracking-widest">{t('loading.generatingImage', lang)}</span>
    </div>
  </div>
)}
