---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { t, type Locale } from '../lib/i18n/index';
import { db } from '../db/index';
import { users, passwordResets } from '../db/schema';
import { eq } from 'drizzle-orm';
import { generateResetToken, hashToken, RESET_EXPIRY_MS } from '../lib/auth/tokens';
import { sendPasswordResetEmail } from '../lib/auth/email';

const lang = (Astro.locals.lang ?? 'en') as Locale;
let submitted = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = (formData.get('email') as string || '').trim().toLowerCase();

  if (email) {
    const user = db.select().from(users).where(eq(users.email, email)).get();
    if (user) {
      const token = generateResetToken();
      db.insert(passwordResets).values({
        userId: user.id,
        token: hashToken(token),
        expiresAt: new Date(Date.now() + RESET_EXPIRY_MS),
      }).run();
      await sendPasswordResetEmail(email, token, lang);
    }
  }
  // Always show success to prevent email enumeration
  submitted = true;
}
---

<BaseLayout title="Kochgeist - Forgot Password">
  <main class="min-h-screen flex items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-10">
        <div class="flex items-center justify-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary text-4xl">restaurant_menu</span>
          <h1 class="font-headline font-extrabold text-3xl tracking-tighter text-primary">Kochgeist</h1>
        </div>
        <h2 class="font-headline font-bold text-2xl text-on-surface mb-2">{t('auth.forgotPassword', lang)}</h2>
        <p class="text-on-surface-variant">{t('auth.forgotPasswordSubtitle', lang)}</p>
      </div>

      {submitted ? (
        <div class="bg-surface-container-low rounded-2xl p-8 text-center space-y-6">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-secondary-container">
            <span class="material-symbols-outlined text-on-secondary-container text-3xl">mark_email_read</span>
          </div>
          <p class="text-on-surface">{t('auth.resetSent', lang)}</p>
          <a href="/login" class="inline-block text-sm text-primary hover:underline">
            {t('auth.backToLogin', lang)}
          </a>
        </div>
      ) : (
        <form method="POST" class="bg-surface-container-low rounded-2xl p-8 space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium text-on-surface mb-2">{t('auth.email', lang)}</label>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">mail</span>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full bg-surface-container-highest rounded-xl py-3 pl-12 pr-4 text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:ring-2 focus:ring-primary/30"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <button
            type="submit"
            class="w-full editorial-gradient text-white font-headline font-bold py-3 rounded-full transition-all active:scale-[0.98]"
          >
            {t('auth.sendResetLink', lang)}
          </button>

          <div class="text-center">
            <a href="/login" class="text-sm text-primary hover:underline">
              {t('auth.backToLogin', lang)}
            </a>
          </div>
        </form>
      )}
    </div>
  </main>
</BaseLayout>
